# New Relic Configuration
# Get your license key from: https://one.newrelic.com/launcher/api-keys-ui.api-keys-launcher
NEW_RELIC_LICENSE_KEY=your_newrelic_license_key_here

# New Relic Region (optional)
# US: US (default) - https://otlp.nr-data.net
# EU: EU - https://otlp.eu01.nr-data.net
NEW_RELIC_REGION=US

# --- CORS (development) --------------------------------------------------------
# As of go-bricks v0.50.0 (ADR-038), permissive "wildcard" dev CORS is opt-in.
# The `make run` target sets CORS_DEV_WILDCARD=true so a browser on any origin can
# call the API during local development. Without it — and without CORS_ORIGINS —
# the server fails closed (no Access-Control-Allow-Origin header) and logs a WARN
# at startup. Production must NOT use the wildcard: set an explicit allowlist.
# CORS_DEV_WILDCARD=true
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
