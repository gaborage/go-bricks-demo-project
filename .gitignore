# Allowlisting gitignore template for GO projects prevents us
# from adding various unwanted local files, such as generated
# files, developer configurations or IDE-specific files etc.
#
# Recommended: Go.AllowList.gitignore

# Ignore everything
*

.gomodcache/
node_modules/

# But not these files...
!/.gitignore

!*.go
!go.sum
!go.mod

!README.md
!LICENSE
!TESTING.md
!CONTRIBUTING.md
!MULTI_TENANT.md

!Makefile

# Example files
!.env.example
!config.example.yaml

# Development config (committed so visitors see all options)
!config.development.yaml

# Multi-tenant migration demo fleet config
!config.multitenant.yaml

# Migration SQL files (single-tenant + schema-per-tenant)
!migrations/**/*.sql

# Flyway configs (per-vendor + multi-tenant)
!flyway/*.conf

# Shell scripts under scripts/
!scripts/*.sh

# Postgres bootstrap SQL for the multi-tenant demo
!etc/docker/postgres/*.sql

# Sample Flyway JSON outputs for go-bricks#376 parser design
!samples/**/*.json
!samples/**/*.md

# TypeScript and Node.js
!package.json
!package-lock.json
!tsconfig.json

!wiki/*

!.github/workflows/*.yml
!.github/workflows/*.yaml
!.github/dependabot.yml

!sonar-project.properties

# Load test files
!loadtests/**/*.ts
!loadtests/**/*.js
!loadtests/**/*.yaml
!loadtests/**/*.md

!tsconfig.json

!.specify/**/*

# Docker infrastructure configs (committed for reproducibility)
!etc/docker/rabbitmq/*.conf

# ...even if they are in subdirectories
!*/